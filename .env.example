# Copy this file to .env and fill in what you need.  (run.sh does this for you.)

# Which LLM backend to use by default: "groq" (cloud, smart) or "ollama" (local).
# You can also switch model/backend live in the Chat UI dropdown — this is just
# the startup default.
LLM_PROVIDER=groq

# --- Groq (used for Groq models) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_key_here
# Optional: override the default Groq model.
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (used for local models) ---
# Run a model locally: `ollama pull qwen2.5:3b` then `ollama serve`.
# Default is qwen2.5:3b (~1.9GB, fits a 4GB GPU, good at JSON + nuance).
# Use llama3.2:1b for a lighter/faster-but-dumber fallback.
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_HOST=http://127.0.0.1:11434

# --- RAG embeddings (optional, #22) ---
# Used for semantic retrieval of past turns. If the model isn't pulled or Ollama
# is down, retrieval falls back to keyword overlap automatically (no key needed).
# EMBED_MODEL=nomic-embed-text

# --- Server / tunnel (optional) ---
# HOST=127.0.0.1            # bind address (run.sh / run.bat honor this)
# PORT=8000                 # change if 8000 is busy
# RATE_LIMIT_PER_MIN=30     # per-IP cap on mutating API calls when exposed (#38)
