# Copy this file to .env and fill in what you need.

# Which LLM backend to use: "groq" (cloud, smart — for dev) or "ollama" (local).
LLM_PROVIDER=groq

# --- Groq (used when LLM_PROVIDER=groq) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_key_here
# Optional: override the Groq model.
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (used when LLM_PROVIDER=ollama) ---
# Run a model locally: `ollama pull qwen2.5:3b` then `ollama serve`.
# Default is qwen2.5:3b (~1.9GB, fits a 4GB GPU, good at JSON + nuance).
# Use llama3.2:1b for a lighter/faster-but-dumber fallback.
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_HOST=http://127.0.0.1:11434
